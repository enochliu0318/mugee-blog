.latest-updates{max-width:700px;margin:4rem auto 0;padding:0 1.5rem}.latest-updates .updates-container{background:var(--alt-bg-color,#e0e0e0);border-radius:1.2rem;padding:2rem 2.5rem;box-shadow:0 2px 8px rgba(0,0,0,8%);transition:box-shadow .2s ease}.latest-updates .updates-container:hover{box-shadow:0 4px 16px rgba(0,0,0,.12)}.latest-updates .updates-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.6rem;padding-bottom:1rem;border-bottom:2px solid var(--darker-alt-bg-color,#ccc)}.latest-updates .updates-header h2{margin:0;font-size:2rem;font-weight:700}.latest-updates .updates-header h2 i{margin-right:.6rem;color:var(--link-color,#1565c0)}.latest-updates .updates-header .source-link a{font-size:1.4rem;color:var(--link-color,#1565c0);text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;opacity:.8;transition:opacity .2s ease}.latest-updates .updates-header .source-link a:hover{opacity:1;text-decoration:underline}.latest-updates .updates-list{list-style:none;margin:0;padding:0}.latest-updates .updates-list li{display:flex;align-items:baseline;padding:.8rem 0;border-bottom:1px solid var(--darker-alt-bg-color,#ccc)}.latest-updates .updates-list li:last-child{border-bottom:none;padding-bottom:0}.latest-updates .updates-list li:first-child{padding-top:0}.latest-updates .updates-list .update-date{flex-shrink:0;width:9rem;font-size:1.3rem;color:var(--alt-fg-color,#000);opacity:.7;font-family:sf mono,Consolas,liberation mono,Menlo,monospace}.latest-updates .updates-list .update-title{font-size:1.6rem;font-weight:600;color:var(--fg-color,#212121);text-decoration:none;line-height:1.4;transition:color .2s ease}.latest-updates .updates-list .update-title:hover{color:var(--link-color,#1565c0);text-decoration:underline}@media only screen and (max-width:768px){.latest-updates{margin-top:2rem;padding:0 1rem}.latest-updates .updates-container{padding:1.5rem}.latest-updates .updates-header{flex-direction:column;align-items:flex-start;gap:.5rem}.latest-updates .updates-header h2{font-size:1.8rem}.latest-updates .updates-list li{flex-direction:column;gap:.3rem}.latest-updates .updates-list .update-date{width:auto;font-size:1.2rem}.latest-updates .updates-list .update-title{font-size:1.5rem}}